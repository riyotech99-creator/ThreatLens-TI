# ThreatLens TI — API Keys Configuration
# Copy this file to .env and fill in your real API keys.
# Get your free API keys from:
#   VirusTotal  → https://www.virustotal.com/gui/my-apikey
#   AbuseIPDB   → https://www.abuseipdb.com/account/api
#   IPInfo      → https://ipinfo.io/account/token
#   OTX         → https://otx.alienvault.com/api
#   Hunter.io   → https://hunter.io/api
#   HIBP        → https://haveibeenpwned.com/API/Key
#   URLScan.io  → https://urlscan.io/user/signup

VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
IPINFO_API_KEY=your_ipinfo_api_key_here
OTX_API_KEY=your_otx_alienvault_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
HIBP_API_KEY=your_hibp_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here
